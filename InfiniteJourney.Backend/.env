# PostgreSQL
POSTGRES_DB=infinite_journey_saas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgresql2002

# Backend API
API_PORT=5274
ASPNETCORE_ENVIRONMENT=Development

# Keycloak issuer — point to your deployed InfiniteJourney.Keycloak instance
KEYCLOAK_AUTHORITY=http://host.docker.internal:8080/realms/InfiniteJourney

# Multi-tenancy
MULTITENANCY_PLATFORM_DOMAIN=infinitejourney.com
